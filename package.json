        "pack": "ncc build",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
        "lint": "eslint src/**/*.ts",
        "lint:report": "eslint --output-file eslint_report.json --format json src/**/*.ts"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@actions/core": "3.0.0",
        "@actions/exec": "3.0.0",
        "@actions/github": "9.0.0",
        "js-yaml": "4.1.1",
        "semver": "7.7.4"
    },
    "devDependencies": {
        "@eslint/eslintrc": "3.3.5",
        "@eslint/js": "10.0.1",
        "@jest/globals": "30.3.0",
        "@types/jest": "30.0.0",
        "@types/js-yaml": "4.0.9",
        "@types/node": "25.5.2",
        "@types/semver": "7.7.1",
        "@typescript-eslint/eslint-plugin": "8.58.0",
        "@typescript-eslint/parser": "8.58.0",
        "@vercel/ncc": "0.38.4",
        "cross-env": "10.1.0",
        "eslint": "10.2.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.5",
        "globals": "17.4.0",
        "jest": "30.3.0",
        "jest-circus": "30.3.0",
        "prettier": "3.8.1",
        "ts-jest": "29.4.9",
        "typescript": "6.0.2"
    },
    "jest": {
        "clearMocks": true,
        "extensionsToTreatAsEsm": [
            ".ts"
        ],
        "moduleFileExtensions": [
            "js",
            "ts"
        ],
        "moduleNameMapper": {
            "^(\\.{1,2}/.*)\\.js$": "$1"
        },
        "testEnvironment": "node",
        "testMatch": [
            "**/*.test.ts"
        ],
        "testRunner": "jest-circus/runner",
        "transform": {
            "^.+\\.ts$": [
                "ts-jest",
                {
                    "useESM": true,
                    "isolatedModules": true
                }
            ]
        },
        "verbose": true
    },
